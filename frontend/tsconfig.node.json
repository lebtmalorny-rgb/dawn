{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist/tsconfig-node",
    "tsBuildInfoFile": "./dist/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
